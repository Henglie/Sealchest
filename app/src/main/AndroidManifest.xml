<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".SealchestApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Sealchest">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Sealchest">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- FileProvider：把内置浏览器导出的解密临时文件（cacheDir/exported）
             以 content:// 授权给「用其它应用打开」的目标 app。仅授临时读权限，
             不暴露其它目录。明文文件用后由浏览器清理。 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- SAF：把解锁的 FAT 卷暴露给系统文件选择器 / 其它 app。
             authority 与代码里的 AUTHORITY 常量一致。
             exported=true + 系统权限 MANAGE_DOCUMENTS：仅系统 DocumentsUI 能绑定，
             第三方 app 只能经系统选择器间接访问，拿不到 Provider 本体。
             grantUriPermissions：允许把单个文档的读权限临时授给打开它的 app。 -->
        <provider
            android:name=".saf.SealchestDocumentsProvider"
            android:authorities="com.henglie.sealchest.documents"
            android:exported="true"
            android:grantUriPermissions="true"
            android:permission="android.permission.MANAGE_DOCUMENTS">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
            </intent-filter>
        </provider>

    </application>

</manifest>

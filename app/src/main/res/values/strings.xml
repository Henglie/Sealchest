    <!-- About -->
    <string name="about_title">About</string>
    <string name="about_button">About</string>
    <string name="about_app_desc">A tool to open VeraCrypt encrypted containers on Android without root, in pure user space.</string>
    <string name="about_author_label">Author</string>
    <string name="about_author">Henglie / EternalBlaze</string>
    <string name="about_project_label">Project</string>
    <string name="about_version_label">Version</string>
    <string name="about_upstream_label">VeraCrypt core</string>
    <string name="about_upstream_commit_label">Pinned commit</string>
    <string name="about_toolchain_label">Build toolchain</string>
    <string name="about_abis_label">ABIs</string>
    <string name="about_supplychain_note">This app compiles VeraCrypt\'s upstream C crypto core, pinned to the commit above. You can audit exactly which source is built at github.com/veracrypt/VeraCrypt.</string>
    <string name="about_credit">The crypto core is ported from VeraCrypt (Apache-2.0 + TrueCrypt License 3.0). Sealchest is an independent product and is not affiliated with, nor does it impersonate, the VeraCrypt or TrueCrypt projects.</string>

    <!-- About -->
    <string name="about_title">حول</string>
    <string name="about_button">حول</string>
    <string name="about_app_desc">أداة لفتح حاويات VeraCrypt المشفّرة على أندرويد بدون صلاحيات الجذر، في مساحة المستخدم بالكامل.</string>
    <string name="about_author_label">المؤلف</string>
    <string name="about_author">Henglie / EternalBlaze</string>
    <string name="about_project_label">المشروع</string>
    <string name="about_version_label">الإصدار</string>
    <string name="about_upstream_label">نواة VeraCrypt</string>
    <string name="about_upstream_commit_label">الالتزام المُثبَّت</string>
    <string name="about_toolchain_label">سلسلة أدوات البناء</string>
    <string name="about_abis_label">ABIs</string>
    <string name="about_supplychain_note">يجمّع هذا التطبيق نواة تشفير VeraCrypt بلغة C الموجودة في المصدر الرئيسي، المثبّتة على الالتزام المذكور أعلاه. يمكنك تدقيق المصدر المبني بالضبط على github.com/veracrypt/VeraCrypt.</string>
    <string name="about_credit">نواة التشفير منقولة من VeraCrypt (Apache-2.0 + ترخيص TrueCrypt 3.0). Sealchest منتج مستقل ولا يتبع ولا ينتحل مشاريع VeraCrypt أو TrueCrypt.</string>

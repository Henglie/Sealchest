    <!-- About -->
    <string name="about_title">Über</string>
    <string name="about_button">Über</string>
    <string name="about_app_desc">Ein Tool, um VeraCrypt-verschlüsselte Container auf Android ohne Root zu öffnen, rein im User-Space.</string>
    <string name="about_author_label">Autor</string>
    <string name="about_author">Henglie / EternalBlaze</string>
    <string name="about_project_label">Projekt</string>
    <string name="about_version_label">Version</string>
    <string name="about_upstream_label">VeraCrypt-Kern</string>
    <string name="about_upstream_commit_label">Angehefteter Commit</string>
    <string name="about_toolchain_label">Build-Toolchain</string>
    <string name="about_abis_label">ABIs</string>
    <string name="about_supplychain_note">Diese App kompiliert den vorgelagerten C-Krypto-Kern von VeraCrypt, angeheftet an den obigen Commit. Sie können genau prüfen, welcher Quellcode gebaut wird, auf github.com/veracrypt/VeraCrypt.</string>
    <string name="about_credit">Der Krypto-Kern ist von VeraCrypt portiert (Apache-2.0 + TrueCrypt-Lizenz 3.0). Sealchest ist ein unabhängiges Produkt, weder mit den VeraCrypt- noch den TrueCrypt-Projekten verbunden, und gibt sich nicht als diese aus.</string>
    <string name="unlock_keyfiles_none">Schlüsseldateien (optional)</string>
    <string name="unlock_keyfiles_selected">Schlüsseldateien: %1$d ausgewählt</string>
    <string name="unlock_keyfiles_clear">Schlüsseldateien löschen</string>
    <!-- Volume header tool (A2: backup / rescue) -->
    <string name="header_tool_entry">Volume-Header-Werkzeuge (Backup / Rettung)</string>
    <string name="header_tool_title">Volume-Header-Werkzeuge</string>
    <string name="header_tool_desc">Ein VeraCrypt-Volume bewahrt einen Backup-Header am Ende des Containers auf. Wenn der primäre Header beschädigt ist und sich das Volume nicht öffnen lässt, stellen Sie ihn aus dem eingebetteten Backup wieder her. Sichern Sie den Header regelmäßig, solange das Volume gesund ist.</string>
    <string name="header_tool_close">Schließen</string>
    <string name="header_export_button">Primären Header in Datei sichern</string>
    <string name="header_export_ok">Header gesichert.</string>
    <string name="header_export_failed">Header-Sicherung fehlgeschlagen.</string>
    <string name="header_rescue_warn">Rettung überschreibt den primären Header mit dem eingebetteten Backup-Header. Sie prüft zuerst, ob sich das Backup mit Ihrem Passwort/Ihren Schlüsseldateien öffnen lässt, und sichert den aktuellen Header in einer Rettungsdatei, aber sie schreibt dennoch in den Container — stellen Sie sicher, dass das Volume nirgendwo anders eingehängt ist.</string>
    <string name="header_rescue_button">Aus eingebettetem Backup-Header retten</string>
    <string name="header_rescue_need_write">Rettung benötigt Schreibrechte (Container erneut mit Schreibzugriff wählen)</string>
    <string name="header_restore_ok">Primärer Header aus dem Backup wiederhergestellt. Versuchen Sie jetzt das Entsperren.</string>
    <string name="header_restore_failed">Wiederherstellung fehlgeschlagen. Der Container wurde nicht verändert.</string>


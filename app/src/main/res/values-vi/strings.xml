    <!-- About -->
    <string name="about_title">Giới thiệu</string>
    <string name="about_button">Giới thiệu</string>
    <string name="about_app_desc">Công cụ mở container VeraCrypt đã mã hóa trên Android không cần root, hoàn toàn trong không gian người dùng.</string>
    <string name="about_author_label">Tác giả</string>
    <string name="about_author">Henglie / EternalBlaze</string>
    <string name="about_project_label">Dự án</string>
    <string name="about_version_label">Phiên bản</string>
    <string name="about_upstream_label">Lõi VeraCrypt</string>
    <string name="about_upstream_commit_label">Commit được ghim</string>
    <string name="about_toolchain_label">Chuỗi công cụ build</string>
    <string name="about_abis_label">ABI</string>
    <string name="about_supplychain_note">Ứng dụng này biên dịch lõi mã hóa C nguồn VeraCrypt, được ghim vào commit ở trên. Bạn có thể kiểm toán chính xác mã nguồn nào được build tại github.com/veracrypt/VeraCrypt.</string>
    <string name="about_credit">Lõi mã hóa được port từ VeraCrypt (Apache-2.0 + TrueCrypt License 3.0). Sealchest là một sản phẩm độc lập và không liên kết, cũng không mạo danh các dự án VeraCrypt hay TrueCrypt.</string>

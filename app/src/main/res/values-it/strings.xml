    <!-- About -->
    <string name="about_title">Informazioni</string>
    <string name="about_button">Informazioni</string>
    <string name="about_app_desc">Uno strumento per aprire container VeraCrypt crittografati su Android senza root, interamente in spazio utente.</string>
    <string name="about_author_label">Autore</string>
    <string name="about_author">Henglie / EternalBlaze</string>
    <string name="about_project_label">Progetto</string>
    <string name="about_version_label">Versione</string>
    <string name="about_upstream_label">Core VeraCrypt</string>
    <string name="about_upstream_commit_label">Commit fissato</string>
    <string name="about_toolchain_label">Toolchain di build</string>
    <string name="about_abis_label">ABI</string>
    <string name="about_supplychain_note">Questa app compila il core crittografico C upstream di VeraCrypt, fissato al commit sopra indicato. Puoi verificare esattamente quale sorgente viene compilato su github.com/veracrypt/VeraCrypt.</string>
    <string name="about_credit">Il core crittografico è portato da VeraCrypt (Apache-2.0 + TrueCrypt License 3.0). Sealchest è un prodotto indipendente e non è affiliato, né si spaccia per, i progetti VeraCrypt o TrueCrypt.</string>
    <string name="unlock_keyfiles_none">File chiave (facoltativi)</string>
    <string name="unlock_keyfiles_selected">File chiave: %1$d selezionati</string>
    <string name="unlock_keyfiles_clear">Cancella file chiave</string>
    <!-- Volume header tool (A2: backup / rescue) -->
    <string name="header_tool_entry">Strumenti intestazione volume (backup / ripristino)</string>
    <string name="header_tool_title">Strumenti intestazione volume</string>
    <string name="header_tool_desc">Un volume VeraCrypt mantiene un\'intestazione di backup alla fine del container. Se l\'intestazione primaria è danneggiata e il volume non si apre, ripristinala dal backup incorporato. Esegui regolarmente il backup dell\'intestazione mentre il volume è integro.</string>
    <string name="header_tool_close">Chiudi</string>
    <string name="header_export_button">Backup dell\'intestazione primaria su file</string>
    <string name="header_export_ok">Backup dell\'intestazione completato.</string>
    <string name="header_export_failed">Backup dell\'intestazione non riuscito.</string>
    <string name="header_rescue_warn">Il ripristino sovrascrive l\'intestazione primaria con l\'intestazione di backup incorporata. Verifica prima che il backup si apra con la tua password/file chiave e salva l\'intestazione corrente in un file di ripristino, ma questa operazione scrive comunque sul container — assicurati che il volume non sia montato altrove.</string>
    <string name="header_rescue_button">Ripristina da intestazione di backup incorporata</string>
    <string name="header_rescue_need_write">Il ripristino richiede l\'autorizzazione di scrittura (riseleziona il container concedendo l\'accesso in scrittura)</string>
    <string name="header_restore_ok">Intestazione primaria ripristinata dal backup. Prova a sbloccare ora.</string>
    <string name="header_restore_failed">Ripristino non riuscito. Il container non è stato modificato.</string>


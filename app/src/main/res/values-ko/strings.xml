    <!-- About -->
    <string name="about_title">정보</string>
    <string name="about_button">정보</string>
    <string name="about_app_desc">Android에서 root 없이 순수 사용자 공간에서 VeraCrypt 암호화 컨테이너를 여는 도구입니다.</string>
    <string name="about_author_label">작성자</string>

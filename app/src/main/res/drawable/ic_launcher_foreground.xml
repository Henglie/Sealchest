<?xml version="1.0" encoding="utf-8"?>
<!--
  匿匣启动图标前景：盾牌 + 挂锁。酒红色调，平面设计 + 色彩层次。
  - 盾牌主体 #8B2D35（主酒红）
  - 盾牌顶部高光带 #B0454E（亮酒红，模拟左上光照）
  - 锁梁+锁体 #4A1518（深酒红，凹陷层次）
  - 锁孔 #F5E6E8（暖白，醒目）
  3 层酒红 + 白锁孔 = 平面但有层次感。adaptive icon 安全区 66dp 居中。
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 盾牌主体：主酒红 -->
    <path
        android:fillColor="#8B2D35"
        android:pathData="M54,26 L78,34 L78,56 C78,72 67,82 54,88 C41,82 30,72 30,56 L30,34 Z" />

    <!-- 盾牌顶部高光带：亮酒红，模拟光照层次 -->
    <path
        android:fillColor="#B0454E"
        android:pathData="M54,26 L78,34 L78,39 L54,31 L30,39 L30,34 Z" />

    <!-- 锁梁（U形弧）：深酒红描边 -->
    <path
        android:strokeColor="#4A1518"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M47,52 C47,43 61,43 61,52" />

    <!-- 锁体（圆角矩形）：深酒红填充 -->
    <path
        android:fillColor="#4A1518"
        android:pathData="M43,50 L65,50 L65,68 C65,72 62,75 58,75 L50,75 C46,75 43,72 43,68 Z" />

    <!-- 锁孔（暖白）：圆+下方梯形 -->
    <path
        android:fillColor="#F5E6E8"
        android:pathData="M54,59 m-2.8,0 a2.8,2.8 0 1 0 5.6,0 a2.8,2.8 0 1 0 -5.6,0 Z" />
    <path
        android:fillColor="#F5E6E8"
        android:pathData="M52.2,60.5 L55.8,60.5 L54.8,67 L53.2,67 Z" />
</vector>

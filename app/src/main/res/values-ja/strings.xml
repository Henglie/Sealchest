    <!-- About -->
    <string name="about_title">アプリについて</string>
    <string name="about_button">アプリについて</string>
    <string name="about_app_desc">Android で root 不要、純粋なユーザースペースで VeraCrypt 暗号化コンテナを開くツールです。</string>
    <string name="about_author_label">作者</string>
    <string name="about_author">Henglie / EternalBlaze</string>
    <string name="about_project_label">プロジェクト</string>
    <string name="about_version_label">バージョン</string>
    <string name="about_upstream_label">VeraCrypt コア</string>
    <string name="about_upstream_commit_label">固定コミット</string>
    <string name="about_toolchain_label">ビルドツールチェーン</string>
    <string name="about_abis_label">ABIs</string>
    <string name="about_supplychain_note">このアプリは VeraCrypt の上流の C 暗号コアを、上記のコミットに固定してコンパイルしています。どのソースがビルドされているかは github.com/veracrypt/VeraCrypt で正確に監査できます。</string>
    <string name="about_credit">暗号コアは VeraCrypt（Apache-2.0 + TrueCrypt License 3.0）から移植されました。Sealchest は独立した製品であり、VeraCrypt や TrueCrypt プロジェクトと提携関係になく、それらを偽装するものでもありません。</string>

    <!-- About -->
    <string name="about_title">Hakkında</string>
    <string name="about_button">Hakkında</string>
    <string name="about_app_desc">Android\'de root\'su, tamamen kullanıcı alanında VeraCrypt şifreli kapsayıcıları açmak için bir araç.</string>
    <string name="about_author_label">Yazar</string>
    <string name="about_author">Henglie / EternalBlaze</string>
    <string name="about_project_label">Proje</string>
    <string name="about_version_label">Sürüm</string>
    <string name="about_upstream_label">VeraCrypt çekirdeği</string>
    <string name="about_upstream_commit_label">Sabitlenmiş commit</string>
    <string name="about_toolchain_label">Derleme araç zinciri</string>
    <string name="about_abis_label">ABIs</string>
    <string name="about_supplychain_note">Bu uygulama, yukarıdaki commit\'e sabitlenmiş VeraCrypt\'ın upstream C şifreleme çekirdeğini derler. Hangi kaynağın derlendiğini github.com/veracrypt/VeraCrypt adresinde tam olarak denetleyebilirsiniz.</string>
    <string name="about_credit">Şifreleme çekirdeği VeraCrypt\'tan (Apache-2.0 + TrueCrypt Lisansı 3.0) aktarılmıştır. Sealchest bağımsız bir üründür ve VeraCrypt veya TrueCrypt projeleriyle bağlantılı değildir, onları taklit etmez.</string>

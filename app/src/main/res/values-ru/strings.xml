    <!-- About -->
    <string name="about_title">О приложении</string>
    <string name="about_button">О приложении</string>
    <string name="about_app_desc">Инструмент для открытия зашифрованных контейнеров VeraCrypt на Android без root, в чистом пользовательском пространстве.</string>
    <string name="about_author_label">Автор</string>
    <string name="about_author">Henglie / EternalBlaze</string>
    <string name="about_project_label">Проект</string>
    <string name="about_version_label">Версия</string>
    <string name="about_upstream_label">Ядро VeraCrypt</string>
    <string name="about_upstream_commit_label">Зафиксированный коммит</string>
    <string name="about_toolchain_label">Инструмент сборки</string>
    <string name="about_abis_label">ABIs</string>
    <string name="about_supplychain_note">Это приложение компилирует крипто-ядро на C из апстрима VeraCrypt, зафиксированное на указанном выше коммите. Вы можете точно проверить, какой исходный код собирается, на github.com/veracrypt/VeraCrypt.</string>
    <string name="about_credit">Крипто-ядро портировано из VeraCrypt (Apache-2.0 + TrueCrypt License 3.0). Sealchest — независимый продукт, не связанный с проектами VeraCrypt или TrueCrypt и не выдающий себя за них.</string>
    <string name="unlock_keyfiles_none">Файлы ключей (необязательно)</string>

    <!-- Change password / PIM / PRF / keyfiles (B1) -->
    <string name="change_pwd_entry">Cambiar contraseña / PIM / archivos llave</string>
    <string name="change_pwd_title">Cambiar contraseña</string>
    <string name="change_pwd_desc">Introduzca arriba la contraseña / PIM / PRF / archivos llave actuales (igual que al desbloquear), luego configure los nuevos aquí. Solo se recifra la cabecera — la clave maestra y sus datos nunca cambian. Antes de escribir se guarda una copia de rescate de la cabecera actual, por si algo sale mal.</string>

    <!-- Volume header tool (A2: backup / rescue) -->
    <string name="header_tool_entry">Công cụ tiêu đề volume (sao lưu / cứu hộ)</string>
    <string name="header_tool_title">Công cụ tiêu đề volume</string>
    <string name="header_tool_desc">Một volume VeraCrypt lưu một tiêu đề sao lưu ở cuối container. Nếu tiêu đề chính bị hỏng và volume không mở được, hãy khôi phục từ bản sao lưu nhúng. Thường xuyên sao lưu tiêu đề khi volume còn khỏe.</string>
    <string name="header_tool_close">Đóng</string>
    <string name="header_export_button">Sao lưu tiêu đề chính ra tệp</string>
    <string name="header_export_ok">Đã sao lưu tiêu đề.</string>
    <string name="header_export_failed">Sao lưu tiêu đề thất bại.</string>
    <string name="header_rescue_warn">Cứu hộ ghi đè tiêu đề chính bằng tiêu đề sao lưu nhúng. Trước tiên nó xác minh bản sao lưu mở được bằng mật khẩu/tệp khóa của bạn và lưu tiêu đề hiện tại vào tệp cứu hộ, nhưng vẫn ghi vào container — hãy đảm bảo volume không được gắn ở nơi khác.</string>
    <string name="header_rescue_button">Cứu hộ từ tiêu đề sao lưu nhúng</string>
    <string name="header_rescue_need_write">Cứu hộ cần quyền ghi (chọn lại container, cấp quyền ghi)</string>

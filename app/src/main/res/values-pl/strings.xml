    <!-- About -->
    <string name="about_title">O aplikacji</string>
    <string name="about_button">O aplikacji</string>
    <string name="about_app_desc">Narzędzie do otwierania zaszyfrowanych kontenerów VeraCrypt na Androidzie bez roota, w czystej przestrzeni użytkownika.</string>
    <string name="about_author_label">Autor</string>
    <string name="about_author">Henglie / EternalBlaze</string>
    <string name="about_project_label">Projekt</string>
    <string name="about_version_label">Wersja</string>
    <string name="about_upstream_label">Rdzeń VeraCrypt</string>
    <string name="about_upstream_commit_label">Przypięty commit</string>
    <string name="about_toolchain_label">Łańcuch narzędzi budowania</string>
    <string name="about_abis_label">ABI</string>
    <string name="about_supplychain_note">Ta aplikacja kompiluje rdzeń kryptograficzny w C z VeraCrypt, przypięty do powyższego commita. Możesz dokładnie zbadać, jaki kod źródłowy jest budowany, na github.com/veracrypt/VeraCrypt.</string>
    <string name="about_credit">Rdzeń kryptograficzny jest portem z VeraCrypt (Apache-2.0 + TrueCrypt License 3.0). Sealchest jest niezależnym produktem i nie jest powiązany z, ani nie podaje się za projekty VeraCrypt lub TrueCrypt.</string>
    <string name="unlock_keyfiles_none">Pliki kluczy (opcjonalne)</string>
    <string name="unlock_keyfiles_selected">Pliki kluczy: wybrano %1$d</string>
    <string name="unlock_keyfiles_clear">Wyczyść pliki kluczy</string>
    <!-- Volume header tool (A2: backup / rescue) -->
    <string name="header_tool_entry">Narzędzia nagłówka wolumenu (kopia zapasowa / ratunkowa)</string>
    <string name="header_tool_title">Narzędzia nagłówka wolumenu</string>
    <string name="header_tool_desc">Wolumen VeraCrypt przechowuje kopię zapasową nagłówka na końcu kontenera. Jeśli główny nagłówek jest uszkodzony i wolumen nie chce się otworzyć, przywróć go z wbudowanej kopii zapasowej. Regularnie twórz kopię zapasową nagłówka, gdy wolumen jest zdrowy.</string>
    <string name="header_tool_close">Zamknij</string>
    <string name="header_export_button">Utwórz kopię zapasową głównego nagłówka do pliku</string>
    <string name="header_export_ok">Utworzono kopię zapasową nagłówka.</string>
    <string name="header_export_failed">Tworzenie kopii zapasowej nagłówka nie powiodło się.</string>
    <string name="header_rescue_warn">Operacja ratunkowa zastępuje główny nagłówek wbudowanym nagłówkiem zapasowym. Najpierw weryfikuje, czy kopia zapasowa otwiera się przy użyciu Twojego hasła/plików kluczy, i zapisuje bieżący nagłówek do pliku ratunkowego, ale nadal zapisuje kontener — upewnij się, że wolumen nie jest zamontowany nigdzie indziej.</string>
    <string name="header_rescue_button">Przywróć z wbudowanego nagłówka zapasowego</string>
    <string name="header_rescue_need_write">Operacja ratunkowa wymaga uprawnień do zapisu (wybierz ponownie kontener, przyznając dostęp do zapisu)</string>
    <string name="header_restore_ok">Główny nagłówek przywrócono z kopii zapasowej. Spróbuj teraz odblokować.</string>
    <string name="header_restore_failed">Przywracanie nie powiodło się. Kontener nie został zmodyfikowany.</string>


    <!-- About -->
    <string name="about_title">Sobre</string>
    <string name="about_button">Sobre</string>
    <string name="about_app_desc">Uma ferramenta para abrir contêineres VeraCrypt criptografados no Android sem root, em espaço de usuário puro.</string>
    <string name="about_author_label">Autor</string>
    <string name="about_author">Henglie / EternalBlaze</string>
    <string name="about_project_label">Projeto</string>
    <string name="about_version_label">Versão</string>
    <string name="about_upstream_label">Núcleo VeraCrypt</string>
    <string name="about_upstream_commit_label">Commit fixado</string>
    <string name="about_toolchain_label">Toolchain de build</string>
    <string name="about_abis_label">ABIs</string>
    <string name="about_supplychain_note">Este app compila o núcleo criptográfico C upstream do VeraCrypt, fixado no commit acima. Você pode auditar exatamente qual código-fonte é compilado em github.com/veracrypt/VeraCrypt.</string>
    <string name="about_credit">O núcleo criptográfico é portado do VeraCrypt (Apache-2.0 + TrueCrypt License 3.0). Sealchest é um produto independente e não é afiliado, nem se faz passar por, os projetos VeraCrypt ou TrueCrypt.</string>
    <string name="unlock_keyfiles_none">Arquivos-chave (opcional)</string>
    <string name="unlock_keyfiles_selected">Arquivos-chave: %1$d selecionados</string>
    <string name="unlock_keyfiles_clear">Limpar arquivos-chave</string>
    <!-- Volume header tool (A2: backup / rescue) -->
    <string name="header_tool_entry">Ferramentas de cabeçalho do volume (backup / recuperação)</string>
    <string name="header_tool_title">Ferramentas de cabeçalho do volume</string>
    <string name="header_tool_desc">Um volume VeraCrypt mantém um cabeçalho de backup no final do contêiner. Se o cabeçalho primário for danificado e o volume não abrir, restaure-o a partir do backup incorporado. Faça backup do cabeçalho regularmente enquanto o volume está íntegro.</string>
    <string name="header_tool_close">Fechar</string>
    <string name="header_export_button">Fazer backup do cabeçalho primário para arquivo</string>
    <string name="header_export_ok">Backup do cabeçalho concluído.</string>
    <string name="header_export_failed">Backup do cabeçalho falhou.</string>
    <string name="header_rescue_warn">A recuperação sobrescreve o cabeçalho primário com o cabeçalho de backup incorporado. Ela primeiro verifica se o backup abre com sua senha/arquivos-chave e salva o cabeçalho atual em um arquivo de recuperação, mas ainda assim grava no contêiner — certifique-se de que o volume não esteja montado em outro lugar.</string>
    <string name="header_rescue_button">Recuperar do cabeçalho de backup incorporado</string>
    <string name="header_rescue_need_write">A recuperação precisa de permissão de gravação (selecione novamente o contêiner concedendo acesso de gravação)</string>
    <string name="header_restore_ok">Cabeçalho primário restaurado do backup. Tente desbloquear agora.</string>
    <string name="header_restore_failed">Falha na restauração. O contêiner não foi modificado.</string>


    <!-- About -->
    <string name="about_title">Acerca de</string>
    <string name="about_button">Acerca de</string>
    <string name="about_app_desc">Una herramienta para abrir contenedores cifrados con VeraCrypt en Android sin root, en espacio de usuario puro.</string>
    <string name="about_author_label">Autor</string>
    <string name="about_author">Henglie / EternalBlaze</string>
    <string name="about_project_label">Proyecto</string>
    <string name="about_version_label">Versión</string>
    <string name="about_upstream_label">Núcleo VeraCrypt</string>
    <string name="about_upstream_commit_label">Commit fijado</string>
    <string name="about_toolchain_label">Toolchain de build</string>
    <string name="about_abis_label">ABIs</string>
    <string name="about_supplychain_note">Esta app compila el núcleo criptográfico C upstream de VeraCrypt, fijado al commit de arriba. Puede auditar exactamente qué fuente se compila en github.com/veracrypt/VeraCrypt.</string>
    <string name="about_credit">El núcleo criptográfico se portó de VeraCrypt (Apache-2.0 + Licencia TrueCrypt 3.0). Sealchest es un producto independiente y no está afiliado a los proyectos VeraCrypt ni TrueCrypt, ni se hace pasar por ellos.</string>
    <string name="unlock_keyfiles_none">Archivos llave (opcional)</string>
    <string name="unlock_keyfiles_selected">Archivos llave: %1$d seleccionado(s)</string>
    <string name="unlock_keyfiles_clear">Limpiar archivos llave</string>
    <!-- Volume header tool (A2: backup / rescue) -->
    <string name="header_tool_entry">Herramientas de cabecera de volumen (copia de seguridad / rescate)</string>
    <string name="header_tool_title">Herramientas de cabecera de volumen</string>
    <string name="header_tool_desc">Un volumen VeraCrypt guarda una cabecera de respaldo al final del contenedor. Si la cabecera principal está dañada y el volumen no abre, restáurela desde el respaldo integrado. Haga copia de la cabecera regularmente mientras el volumen esté sano.</string>
    <string name="header_tool_close">Cerrar</string>
    <string name="header_export_button">Copiar cabecera principal a archivo</string>
    <string name="header_export_ok">Cabecera respaldada.</string>
    <string name="header_export_failed">Falló el respaldo de cabecera.</string>
    <string name="header_rescue_warn">El rescate sobrescribe la cabecera principal con la cabecera de respaldo integrada. Primero verifica que el respaldo abre con su contraseña/archivos llave y guarda la cabecera actual en un archivo de rescate, pero aun así escribe en el contenedor — asegúrese de que el volumen no esté montado en otro sitio.</string>
    <string name="header_rescue_button">Rescatar desde cabecera de respaldo integrada</string>
    <string name="header_rescue_need_write">El rescate necesita permiso de escritura (vuelva a elegir el contenedor concediendo acceso de escritura)</string>
    <string name="header_restore_ok">Cabecera principal restaurada desde el respaldo. Pruebe a desbloquear ahora.</string>
    <string name="header_restore_failed">Restauración fallida. El contenedor no se modificó.</string>


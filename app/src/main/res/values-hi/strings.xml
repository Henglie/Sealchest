    <!-- About -->
    <string name="about_title">के बारे में</string>
    <string name="about_button">के बारे में</string>
    <string name="about_app_desc">बिना रूट के, पूर्ण उपयोगकर्ता स्थान में, Android पर VeraCrypt एन्क्रिप्टेड कंटेनर खोलने का एक उपकरण।</string>
    <string name="about_author_label">लेखक</string>
    <string name="about_author">Henglie / EternalBlaze</string>
    <string name="about_project_label">प्रोजेक्ट</string>
    <string name="about_version_label">संस्करण</string>
    <string name="about_upstream_label">VeraCrypt कोर</string>
    <string name="about_upstream_commit_label">पिन किया गया कमिट</string>
    <string name="about_toolchain_label">बिल्ड टूलचेन</string>
    <string name="about_abis_label">ABIs</string>
    <string name="about_supplychain_note">यह ऐप VeraCrypt के अपस्ट्रीम C क्रिप्टो कोर को संकलित करता है, जो ऊपर दिए गए कमिट पर पिन है। आप github.com/veracrypt/VeraCrypt पर सटीक रूप से देख सकते हैं कि कौन सा स्रोत बनाया गया है।</string>
    <string name="about_credit">क्रिप्टो कोर VeraCrypt (Apache-2.0 + TrueCrypt लाइसेंस 3.0) से पोर्ट किया गया है। Sealchest एक स्वतंत्र उत्पाद है और VeraCrypt या TrueCrypt प्रोजेक्ट्स से संबद्ध नहीं है, न ही इनका प्रतिरूप करता है।</string>
    <string name="unlock_keyfiles_none">कीफ़ाइलें (वैकल्पिक)</string>
    <string name="unlock_keyfiles_selected">कीफ़ाइलें: %1$d चयनित</string>
    <string name="unlock_keyfiles_clear">कीफ़ाइलें साफ़ करें</string>
    <!-- Volume header tool (A2: backup / rescue) -->
    <string name="header_tool_entry">वॉल्यूम हेडर उपकरण (बैकअप / रेस्क्यू)</string>
    <string name="header_tool_title">वॉल्यूम हेडर उपकरण</string>
    <string name="header_tool_desc">एक VeraCrypt वॉल्यूम कंटेनर के अंत में एक बैकअप हेडर रखता है। यदि प्राथमिक हेडर क्षतिग्रस्त है और वॉल्यूम नहीं खुलता है, तो इसे एम्बेडेड बैकअप से पुनर्स्थापित करें। वॉल्यूम स्वस्थ होने पर नियमित रूप से हेडर का बैकअप लें।</string>
    <string name="header_tool_close">बंद करें</string>
    <string name="header_export_button">प्राथमिक हेडर को फ़ाइल में बैकअप करें</string>
    <string name="header_export_ok">हेडर बैकअप हो गया।</string>
    <string name="header_export_failed">हेडर बैकअप विफल।</string>
    <string name="header_rescue_warn">रेस्क्यू एम्बेडेड बैकअप हेडर के साथ प्राथमिक हेडर को अधिलेखित करता है। यह पहले सत्यापित करता है कि बैकअप आपके पासवर्ड/कीफ़ाइलों से खुलता है और वर्तमान हेडर को रेस्क्यू फ़ाइल में सहेजता है, लेकिन यह अभी भी कंटेनर को लिखता है — सुनिश्चित करें कि वॉल्यूम कहीं और माउंट नहीं है।</string>
    <string name="header_rescue_button">एम्बेडेड बैकअप हेडर से रेस्क्यू करें</string>
    <string name="header_rescue_need_write">रेस्क्यू को लेखन अनुमति चाहिए (कंटेनर को पुनः चुनें और लेखन पहुँच प्रदान करें)</string>
    <string name="header_restore_ok">प्राथमिक हेडर बैकअप से पुनर्स्थापित हो गया। अब अनलॉक करने का प्रयास करें।</string>
    <string name="header_restore_failed">पुनर्स्थापना विफल। कंटेनर को संशोधित नहीं किया गया।</string>


<?xml version="1.0" encoding="utf-8"?>
<!--
  前景：经典安卓机器人 Bugdroid（绿色），居中绘制。
  adaptive icon 前景画布 108x108dp，安全区 66dp 居中（半径约 33dp）。
  机器人主体含头、两眼、两触角、身躯、两臂、两腿，整体落在中央安全区内。
  颜色用官方 Bugdroid 绿 #3DDC84。
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group android:name="bugdroid">
        <!-- 触角（左） -->
        <path
            android:strokeColor="#3DDC84"
            android:strokeWidth="2.2"
            android:strokeLineCap="round"
            android:pathData="M44.5,38 L40,31.5" />
        <!-- 触角（右） -->
        <path
            android:strokeColor="#3DDC84"
            android:strokeWidth="2.2"
            android:strokeLineCap="round"
            android:pathData="M63.5,38 L68,31.5" />

        <!-- 头部（半圆穹顶） + 身躯（圆角矩形）合为主体 -->
        <!-- 头部半圆，圆心 (54,46)，半径 13 -->
        <path
            android:fillColor="#3DDC84"
            android:pathData="M41,46 a13,13 0 0 1 26,0 Z" />
        <!-- 眼睛（背景挖空成两点白底机器眼，用底色覆盖） -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M48.2,42.5 m-1.7,0 a1.7,1.7 0 1 0 3.4,0 a1.7,1.7 0 1 0 -3.4,0 Z" />
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M59.8,42.5 m-1.7,0 a1.7,1.7 0 1 0 3.4,0 a1.7,1.7 0 1 0 -3.4,0 Z" />

        <!-- 身躯：圆角矩形，x 41..67，y 48..70 -->
        <path
            android:fillColor="#3DDC84"
            android:pathData="M41,49 L67,49 L67,68 a2,2 0 0 1 -2,2 L43,70 a2,2 0 0 1 -2,-2 Z" />

        <!-- 左臂 -->
        <path
            android:fillColor="#3DDC84"
            android:pathData="M35,50 a2.5,2.5 0 0 1 5,0 L40,63 a2.5,2.5 0 0 1 -5,0 Z" />
        <!-- 右臂 -->
        <path
            android:fillColor="#3DDC84"
            android:pathData="M68,50 a2.5,2.5 0 0 1 5,0 L73,63 a2.5,2.5 0 0 1 -5,0 Z" />

        <!-- 左腿 -->
        <path
            android:fillColor="#3DDC84"
            android:pathData="M46,68 a2.5,2.5 0 0 1 5,0 L51,78 a2.5,2.5 0 0 1 -5,0 Z" />
        <!-- 右腿 -->
        <path
            android:fillColor="#3DDC84"
            android:pathData="M57,68 a2.5,2.5 0 0 1 5,0 L62,78 a2.5,2.5 0 0 1 -5,0 Z" />
    </group>
</vector>

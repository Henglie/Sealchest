    <!-- About -->
    <string name="about_title">Over</string>
    <string name="about_button">Over</string>
    <string name="about_app_desc">Een hulpmiddel om VeraCrypt-versleutelde containers op Android te openen zonder root, volledig in gebruikersruimte.</string>
    <string name="about_author_label">Auteur</string>
    <string name="about_author">Henglie / EternalBlaze</string>
    <string name="about_project_label">Project</string>
    <string name="about_version_label">Versie</string>
    <string name="about_upstream_label">VeraCrypt-kern</string>
    <string name="about_upstream_commit_label">Vastgepinde commit</string>
    <string name="about_toolchain_label">Build-toolchain</string>
    <string name="about_abis_label">ABI\'s</string>
    <string name="about_supplychain_note">Deze app compileert de upstream C-cryptografische kern van VeraCrypt, vastgepind op de commit hierboven. U kunt precies auditeren welke broncode wordt gebouwd op github.com/veracrypt/VeraCrypt.</string>
    <string name="about_credit">De cryptografische kern is overgenomen van VeraCrypt (Apache-2.0 + TrueCrypt License 3.0). Sealchest is een onafhankelijk product en is niet gelieerd aan, noch doet het zich voor als, de VeraCrypt- of TrueCrypt-projecten.</string>
    <string name="unlock_keyfiles_none">Sleutelbestanden (optioneel)</string>
    <string name="unlock_keyfiles_selected">Sleutelbestanden: %1$d geselecteerd</string>
    <string name="unlock_keyfiles_clear">Sleutelbestanden wissen</string>
    <!-- Volume header tool (A2: backup / rescue) -->
    <string name="header_tool_entry">Volumekop-tools (backup / herstel)</string>
    <string name="header_tool_title">Volumekop-tools</string>
    <string name="header_tool_desc">Een VeraCrypt-volume bewaart een backup-kop aan het einde van de container. Als de primaire kop beschadigd is en het volume niet opent, herstel deze dan vanuit de ingebouwde backup. Maak regelmatig een backup van de kop zolang het volume gezond is.</string>
    <string name="header_tool_close">Sluiten</string>
    <string name="header_export_button">Back-up van primaire kop naar bestand</string>
    <string name="header_export_ok">Back-up van kop gemaakt.</string>
    <string name="header_export_failed">Back-up van kop mislukt.</string>
    <string name="header_rescue_warn">Herstel overschrijft de primaire kop met de ingebouwde backup-kop. Het verifieert eerst dat de backup opent met uw wachtwoord/sleutelbestanden en slaat de huidige kop op in een herstelbestand, maar dit schrijft alsnog naar de container — zorg dat het volume nergens anders is gekoppeld.</string>
    <string name="header_rescue_button">Herstellen vanuit ingebouwde backup-kop</string>
    <string name="header_rescue_need_write">Herstel vereist schrijfrechten (kies de container opnieuw en verleen schrijftoegang)</string>
    <string name="header_restore_ok">Primaire kop hersteld vanuit back-up. Probeer nu te ontgrendelen.</string>
    <string name="header_restore_failed">Herstellen mislukt. De container is niet gewijzigd.</string>


    <string name="create_entropy_title">Recoger aleatoriedad</string>
    <string name="create_entropy_hint">Deslice el dedo por el recuadro de abajo. Sus movimientos impredecibles añaden entropía a la clave maestra (como mover el ratón en VeraCrypt de escritorio).</string>
    <string name="create_entropy_progress">Siga deslizando… %1$d%%</string>

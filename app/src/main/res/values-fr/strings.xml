    <!-- About -->
    <string name="about_title">À propos</string>
    <string name="about_button">À propos</string>
    <string name="about_app_desc">Un outil pour ouvrir des conteneurs chiffrés VeraCrypt sur Android sans root, en pur espace utilisateur.</string>
    <string name="about_author_label">Auteur</string>
    <string name="about_author">Henglie / EternalBlaze</string>
    <string name="about_project_label">Projet</string>
    <string name="about_version_label">Version</string>
    <string name="about_upstream_label">Cœur VeraCrypt</string>
    <string name="about_upstream_commit_label">Commit fixé</string>
    <string name="about_toolchain_label">Chaîne de build</string>
    <string name="about_abis_label">ABI</string>
    <string name="about_supplychain_note">Cette appli compile le cœur cryptographique C amont de VeraCrypt, fixé au commit ci-dessus. Vous pouvez auditer exactement la source compilée sur github.com/veracrypt/VeraCrypt.</string>
    <string name="about_credit">Le cœur cryptographique est porté de VeraCrypt (Apache-2.0 + TrueCrypt License 3.0). Sealchest est un produit indépendant, non affilié aux projets VeraCrypt ou TrueCrypt et ne se fait pas passer pour eux.</string>

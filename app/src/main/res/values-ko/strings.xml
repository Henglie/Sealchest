    <string name="header_tool_title">볼륨 헤더 도구</string>
    <string name="header_tool_desc">VeraCrypt 볼륨은 컨테이너 끝에 백업 헤더를 보관합니다. 주 헤더가 손상되어 볼륨이 열리지 않으면 내장 백업에서 복원하십시오. 볼륨이 정상일 때 정기적으로 헤더를 백업하십시오.</string>
    <string name="header_tool_close">닫기</string>
    <string name="header_export_button">주 헤더를 파일에 백업</string>

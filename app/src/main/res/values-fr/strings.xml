    <!-- Volume header tool (A2: backup / rescue) -->
    <string name="header_tool_entry">Outils d\'en-tête de volume (sauvegarde / secours)</string>
    <string name="header_tool_title">Outils d\'en-tête de volume</string>
    <string name="header_tool_desc">Un volume VeraCrypt conserve un en-tête de sauvegarde à la fin du conteneur. Si l\'en-tête principal est endommagé et que le volume ne s\'ouvre plus, restaurez-le depuis la sauvegarde intégrée. Sauvegardez l\'en-tête régulièrement tant que le volume est sain.</string>
    <string name="header_tool_close">Fermer</string>
    <string name="header_export_button">Sauvegarder l\'en-tête principal dans un fichier</string>
    <string name="header_export_ok">En-tête sauvegardé.</string>
    <string name="header_export_failed">Échec de la sauvegarde de l\'en-tête.</string>
    <string name="header_rescue_warn">La restauration de secours écrase l\'en-tête principal par l\'en-tête de sauvegarde intégré. Elle vérifie d\'abord que la sauvegarde s\'ouvre avec votre mot de passe/fichiers-clés et enregistre l\'en-tête actuel dans un fichier de secours, mais elle écrit tout de même dans le conteneur — assurez-vous que le volume n\'est pas monté ailleurs.</string>
    <string name="header_rescue_button">Restaurer depuis l\'en-tête de sauvegarde intégré</string>
    <string name="header_rescue_need_write">La restauration de secours nécessite l\'accès en écriture (re-sélectionnez le conteneur en accordant l\'accès en écriture)</string>
    <string name="header_restore_ok">En-tête principal restauré depuis la sauvegarde. Essayez de déverrouiller maintenant.</string>
    <string name="header_restore_failed">Échec de la restauration. Le conteneur n\'a pas été modifié.</string>

